generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  role        Role     @default(DEPARTMENT)
  
  createdJobs Job[]    @relation("JobCreator")
  postedJobs  Job[]    @relation("JobPosters")

  linkedinId      String?  
  linkedinToken   String?  
  linkedinExpires DateTime?

  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?

  scheduledInterviews Interview[] @relation("UserScheduledInterviews")

}

model Candidate {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  cvData    CvData?
  resumes   Resume[]
}

model Job {
  id             Int            @id @default(autoincrement())
  title          String
  department     String
  location       String
  employmentType EmploymentType
  workMode       WorkMode
  status         JobStatus      @default(Open)
  createdBy      Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deadline       DateTime?
  creator        User           @relation("JobCreator", fields: [createdBy], references: [id])
  details        JobDetails?
  posters        User[]         @relation("JobPosters")
  resumes   Resume[]
}

model JobDetails {
  jobId            Int      @id
  description      String
  requirements     String[]
  responsibilities String[]
  experienceLevel  Int
  salaryMin        Int
  salaryMax        Int
  job              Job      @relation(fields: [jobId], references: [id])
}


enum Role {
  HR
  DEPARTMENT
}


enum EmploymentType {
  FullTime
  PartTime
  Internship
}

enum WorkMode {
  Onsite
  Remote
  Hybrid
}

enum JobStatus {
  Open
  Closed
}

model CvData {
  id              Int      @id @default(autoincrement())
  phone           String? 
  address         String?
  education       Json?
  work_experience Json?
  skills          String[]
  projects        Json?
  certifications  Json?

  candidateId Int      @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id])
}

model Interview {
  id            Int      @id @default(autoincrement())

  candidateEmail String
  jobId         Int?
  scheduledBy   Int      // User (Hiring Manager)

  date          DateTime
  startTime     DateTime
  endTime       DateTime

  mode          InterviewMode
  meetLink      String?
  notes         String?

  status        InterviewStatus @default(scheduled)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

   scheduler     User @relation("UserScheduledInterviews", fields: [scheduledBy], references: [id])
}

enum InterviewMode {
  google_meet
  on_site
}

enum InterviewStatus {
  pending
  scheduled
  interviewed

}

model Resume {
  id           Int        @id @default(autoincrement())
  originalName String
  parsedData   Json
  uploadedAt   DateTime   @default(now())
  candidateId  Int?       @unique
  job_ID       Int?       @unique
  candidate    Candidate? @relation(fields: [candidateId], references: [id])
  Job          Job?       @relation(fields: [job_ID], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

