generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int         @id @default(autoincrement())
  email               String      @unique
  password            String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  role                Role        @default(DEPARTMENT)
  linkedinExpires     DateTime?
  linkedinId          String?
  linkedinToken       String?
  googleAccessToken   String?
  googleRefreshToken  String?
  googleTokenExpiry   DateTime?
  assignedInterviews  Interview[] @relation("UserAssignedInterviews")
  scheduledInterviews Interview[] @relation("UserScheduledInterviews")
  createdJobs         Job[]       @relation("JobCreator")
  postedJobs          Job[]       @relation("JobPosters")
}

model Candidate {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String?
  createdAt    DateTime      @default(now())
  authProvider String        @default("local")
  googleId     String?       @unique
  applications Application[]
  cvData       CvData?
  resumes      Resume[]
}

model Job {
  id             Int               @id @default(autoincrement())
  title          String
  department     String
  location       String
  employmentType EmploymentType
  workMode       WorkMode
  status         JobStatus         @default(Open)
  createdBy      Int
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deadline       DateTime?
  keywords       String[]          @default([])
  applications   Application[]
  creator        User              @relation("JobCreator", fields: [createdBy], references: [id])
  details        JobDetails?
  JobQuestion    JobQuestion[]
  scoringConfig  JobScoringConfig?
  posters        User[]            @relation("JobPosters")
}

model JobDetails {
  jobId            Int      @id
  description      String
  requirements     String[]
  responsibilities String[]
  experienceLevel  Int
  salaryMin        Int
  salaryMax        Int
  minDegreeLevel   String   @default("BSC")
  requiredDegrees  String[] @default([])
  job              Job      @relation(fields: [jobId], references: [id])
}

model JobScoringConfig {
  id               Int      @id @default(autoincrement())
  jobId            Int      @unique
  skillsWeight     Float    @default(0.4)
  experienceWeight Float    @default(0.4)
  educationWeight  Float    @default(0.2)
  considerCGPA     Boolean  @default(false)
  minCGPA          Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model CvData {
  id                  Int       @id @default(autoincrement())
  phone               String?
  address             String?
  education           Json?
  work_experience     Json?
  skills              String[]
  projects            Json?
  certifications      Json?
  experienceSummary   String?
  candidateId         Int       @unique
  candidate           Candidate @relation(fields: [candidateId], references: [id])
}

model Interview {
  id                Int             @id @default(autoincrement())
  scheduledBy       Int
  startTime         DateTime
  endTime           DateTime
  mode              InterviewMode
  meetLink          String?
  notes             String?
  status            InterviewStatus @default(scheduled)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  assignedToId      Int?
  applicationId     Int             @unique
  round             Int             @default(1)
  interviewFeedback String?
  application       Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  assignedTo        User?           @relation("UserAssignedInterviews", fields: [assignedToId], references: [id])
  scheduler         User            @relation("UserScheduledInterviews", fields: [scheduledBy], references: [id])
}

model Resume {
  id           Int           @id @default(autoincrement())
  originalName String
  parsedData   Json
  uploadedAt   DateTime      @default(now())
  candidateId  Int?
  pdfUrl       String
  applications Application[]
  candidate    Candidate?    @relation(fields: [candidateId], references: [id])
}

model Application {
  id             Int               @id @default(autoincrement())
  candidateId    Int
  jobId          Int
  resumeId       Int
  status         ApplicationStatus @default(pending)
  appliedAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  score          Float?
  scoreBreakdown Json?
  candidate      Candidate         @relation(fields: [candidateId], references: [id])
  job            Job               @relation(fields: [jobId], references: [id])
  resume         Resume            @relation(fields: [resumeId], references: [id])
  interview      Interview?

  @@unique([candidateId, jobId])
}

model QuestionBank {
  id           Int           @id @default(autoincrement())
  question     String        @unique
  briefAnswer  String?
  difficulty   String
  category     String
  tags         String[]
  createdAt    DateTime      @default(now())
  jobQuestions JobQuestion[]
}

model JobQuestion {
  id         Int               @id @default(autoincrement())
  jobId      Int
  questionId Int
  status     JobQuestionStatus @default(pending)
  addedAt    DateTime          @default(now())
  job        Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  question   QuestionBank      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([jobId, questionId])
}

model DegreeEmbedding {
  id        Int     @id @default(autoincrement())
  degree    String  @unique
  embedding Float[]
}

enum ApplicationStatus {
  pending
  reviewed
  shortlisted
  rejected
  accepted
}

enum Role {
  HR
  DEPARTMENT
}

enum EmploymentType {
  FullTime
  PartTime
  Internship
}

enum WorkMode {
  Onsite
  Remote
  Hybrid
}

enum JobStatus {
  Open
  Closed
}

enum InterviewMode {
  google_meet
  on_site
}

enum InterviewStatus {
  scheduled
  accepted
  rejected
}

enum JobQuestionStatus {
  pending
  saved
}
