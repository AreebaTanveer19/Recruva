generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int         @id @default(autoincrement())
  email               String      @unique
  password            String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  role                Role        @default(DEPARTMENT)
  linkedinExpires     DateTime?
  linkedinId          String?
  linkedinToken       String?
  googleAccessToken   String?
  googleRefreshToken  String?
  googleTokenExpiry   DateTime?
  scheduledInterviews Interview[] @relation("UserScheduledInterviews")
  createdJobs         Job[]       @relation("JobCreator")
  postedJobs          Job[]       @relation("JobPosters")
}

model Candidate {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  googleId     String?  @unique
  authProvider String   @default("local")
  createdAt    DateTime      @default(now())
  applications Application[]
  cvData       CvData?
  resumes      Resume[]
}

model Job {
  id             Int            @id @default(autoincrement())
  title          String
  department     String
  location       String
  employmentType EmploymentType
  workMode       WorkMode
  status         JobStatus      @default(Open)
  createdBy      Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deadline       DateTime?
  applications   Application[]
  creator        User           @relation("JobCreator", fields: [createdBy], references: [id])
  details        JobDetails?
  posters        User[]         @relation("JobPosters")
}

model JobDetails {
  jobId            Int      @id
  description      String
  requirements     String[]
  responsibilities String[]
  experienceLevel  Int
  salaryMin        Int
  salaryMax        Int
  job              Job      @relation(fields: [jobId], references: [id])
}

model CvData {
  id              Int       @id @default(autoincrement())
  phone           String?
  address         String?
  education       Json?
  work_experience Json?
  skills          String[]
  projects        Json?
  certifications  Json?
  candidateId     Int       @unique
  candidate       Candidate @relation(fields: [candidateId], references: [id])
}

model Interview {
  id             Int             @id @default(autoincrement())
  candidateEmail String
  jobId          Int?
  scheduledBy    Int
  date           DateTime
  startTime      DateTime
  endTime        DateTime
  mode           InterviewMode
  meetLink       String?
  notes          String?
  status         InterviewStatus @default(scheduled)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scheduler      User            @relation("UserScheduledInterviews", fields: [scheduledBy], references: [id])
}

model Resume {
  id           Int           @id @default(autoincrement())
  originalName String
  parsedData   Json
  uploadedAt   DateTime      @default(now())
  candidateId  Int?
  pdfUrl       String
  applications Application[]
  candidate    Candidate?    @relation(fields: [candidateId], references: [id])
}

model Application {
  id          Int               @id @default(autoincrement())
  candidateId Int
  jobId       Int
  resumeId    Int
  status      ApplicationStatus @default(pending)
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  candidate   Candidate         @relation(fields: [candidateId], references: [id])
  job         Job               @relation(fields: [jobId], references: [id])
  resume      Resume            @relation(fields: [resumeId], references: [id])

  @@unique([candidateId, jobId])
}

enum ApplicationStatus {
  pending
  reviewed
  shortlisted
  rejected
  accepted
}

enum Role {
  HR
  DEPARTMENT
}

enum EmploymentType {
  FullTime
  PartTime
  Internship
}

enum WorkMode {
  Onsite
  Remote
  Hybrid
}

enum JobStatus {
  Open
  Closed
}

enum InterviewMode {
  google_meet
  on_site
}

enum InterviewStatus {
  pending
  scheduled
  interviewed
}
